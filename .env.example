# SMTP Configuration for sending emails (e.g., using Gmail)
# Note: For Gmail, you might need to create an "App Password"
# https://support.google.com/accounts/answer/185833
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=votre_email@gmail.com
SMTP_PASS=votre_mot_de_passe_application
SMTP_FROM_EMAIL=votre_email@gmail.com # The "from" address displayed to recipient
SMTP_TO_EMAIL=destinataire@example.com # Where you want to receive contact form submissions
